{
  "components": {
    "schemas": {
      "CreateStrategyRequest": {
        "properties": {
          "qty": {
            "title": "Qty",
            "type": "integer"
          },
          "stop_loss_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stop Loss Pct"
          },
          "strategy_type": {
            "title": "Strategy Type",
            "type": "string"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          },
          "take_profit_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Take Profit Pct"
          },
          "trailing_stop_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Trailing Stop Pct"
          }
        },
        "required": [
          "strategy_type",
          "symbol",
          "qty"
        ],
        "title": "CreateStrategyRequest",
        "type": "object"
      },
      "EnableRequest": {
        "properties": {
          "enabled": {
            "title": "Enabled",
            "type": "boolean"
          }
        },
        "required": [
          "enabled"
        ],
        "title": "EnableRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PlaceOrderRequest": {
        "properties": {
          "confirm_execution": {
            "default": false,
            "title": "Confirm Execution",
            "type": "boolean"
          },
          "price": {
            "title": "Price",
            "type": "number"
          },
          "qty": {
            "title": "Qty",
            "type": "integer"
          },
          "side": {
            "default": "buy",
            "title": "Side",
            "type": "string"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          }
        },
        "required": [
          "symbol",
          "qty",
          "price"
        ],
        "title": "PlaceOrderRequest",
        "type": "object"
      },
      "PositionSizingRequest": {
        "description": "Request for sizing a position.",
        "properties": {
          "available_capital": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Available Capital"
          },
          "lot_size": {
            "default": 1,
            "title": "Lot Size",
            "type": "integer"
          },
          "max_position_value": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Position Value"
          },
          "max_position_weight_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Position Weight Pct"
          },
          "method": {
            "title": "Method",
            "type": "string"
          },
          "price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Price"
          },
          "risk_budget": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Risk Budget"
          },
          "stop_loss_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stop Loss Pct"
          },
          "symbol": {
            "title": "Symbol",
            "type": "string"
          },
          "target_value": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target Value"
          },
          "target_weight_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target Weight Pct"
          }
        },
        "required": [
          "symbol",
          "method"
        ],
        "title": "PositionSizingRequest",
        "type": "object"
      },
      "RebalanceRequest": {
        "description": "Request for a dry-run rebalance plan.",
        "properties": {
          "cash_buffer_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ],
            "default": "0",
            "title": "Cash Buffer Pct"
          },
          "drift_threshold_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              }
            ],
            "default": "1",
            "title": "Drift Threshold Pct"
          },
          "liquidate_unmentioned": {
            "default": false,
            "title": "Liquidate Unmentioned",
            "type": "boolean"
          },
          "lot_size": {
            "default": 1,
            "title": "Lot Size",
            "type": "integer"
          },
          "max_position_weight_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Position Weight Pct"
          },
          "target_weights": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                  "type": "string"
                }
              ]
            },
            "title": "Target Weights",
            "type": "object"
          }
        },
        "required": [
          "target_weights"
        ],
        "title": "RebalanceRequest",
        "type": "object"
      },
      "StartRequest": {
        "properties": {
          "confirm_execution": {
            "default": false,
            "title": "Confirm Execution",
            "type": "boolean"
          },
          "dry_run": {
            "default": false,
            "title": "Dry Run",
            "type": "boolean"
          },
          "interval": {
            "default": 60,
            "title": "Interval",
            "type": "integer"
          }
        },
        "title": "StartRequest",
        "type": "object"
      },
      "StopRequest": {
        "properties": {
          "confirm_execution": {
            "default": false,
            "title": "Confirm Execution",
            "type": "boolean"
          },
          "force": {
            "default": false,
            "title": "Force",
            "type": "boolean"
          }
        },
        "title": "StopRequest",
        "type": "object"
      },
      "TimeFrame": {
        "description": "Supported timeframes for historical data.\n\nValues match Alpaca API naming convention for easy mapping.",
        "enum": [
          "1Day",
          "1Hour",
          "15Min",
          "5Min",
          "1Min"
        ],
        "title": "TimeFrame",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Kodiak headless trading and research API. All endpoints live under /v1/. Authenticate with: Authorization: Bearer <KODIAK_API_TOKEN>.",
    "title": "Kodiak REST API",
    "version": "2.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/engine/start": {
      "post": {
        "description": "Start the trading engine.",
        "operationId": "start_v1_engine_start_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Start V1 Engine Start Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Start",
        "tags": [
          "engine"
        ]
      }
    },
